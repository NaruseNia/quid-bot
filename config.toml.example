[bot]
# デフォルトのAIプロバイダー: "openrouter" | "openai" | "anthropic"
default_ai_provider = "openrouter"
# OpenRouterで使用するモデル
default_model = "openai/gpt-4o-mini"

[pomodoro]
default_work_min = 25
default_break_min = 5

[database]
path = "data/quid.db"

[audio]
# アラーム通知音
alarm_file = "assets/alarm.mp3"
# ポモドーロ完了音
pomo_file = "assets/pomo.mp3"
# VC内に誰もいなくなった後、自動退出するまでの秒数
auto_leave_timeout_sec = 30
